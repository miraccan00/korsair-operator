# BSO Operator — Local Development Environment
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# For Helm/production: use ConfigMap or Secret env injection.

# ─── Slack ────────────────────────────────────────────────────────────────────
# Incoming Webhook URL for batch scan notifications.
# Leave empty to disable Slack notifications.
BSO_SLACK_WEBHOOK_URL=

# ─── Timing Intervals ─────────────────────────────────────────────────────────
# How often to re-discover images from the cluster and requeue.
# Format: Go duration string (e.g. 30s, 5m, 1h)
# Default: 5m
BSO_DISCOVERY_INTERVAL=5m

# How often to poll running Trivy jobs for completion.
# Default: 15s
BSO_POLL_INTERVAL=15s

# Minimum time between successive Slack notifications for the same SecurityScanConfig.
# Prevents alert spam when new images are discovered frequently.
# Can also be overridden per-CR via spec.notificationCooldown.
# Default: 1h
BSO_NOTIFICATION_COOLDOWN=1h

# ─── Concurrency ──────────────────────────────────────────────────────────────
# Maximum number of simultaneously Running/Pending ImageScanJobs.
# Default: 10
BSO_MAX_CONCURRENT_SCANS=5

# ─── Scan Job Cleanup ─────────────────────────────────────────────────────────
# How often to run the cleanup loop (deletes old completed/failed ImageScanJobs).
# Default: 5m
BSO_CLEANUP_INTERVAL=5m

# Delete completed/failed ImageScanJobs older than this duration.
# The owned batch/v1 Jobs are cascade-deleted automatically.
# Default: 1h
BSO_SCAN_JOB_RETENTION=1h

# ─── Kubeconfig (local dev only) ──────────────────────────────────────────────
# KUBECONFIG is auto-detected by the Makefile as $HOME/.kube/config.
# Override here only if your kubeconfig is in a non-standard location:
# KUBECONFIG=/custom/path/to/kubeconfig
