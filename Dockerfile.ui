# ── Stage 1: Build React frontend with pnpm ──────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /frontend

RUN corepack enable

COPY frontend/package.json frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY frontend/ .
RUN pnpm run build
RUN pnpm prune --prod

# ── Stage 2: Production Node server (no nginx) ───────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=8080
ENV HOST=0.0.0.0
# API_URL: Korsair API backend. Override at runtime with -e API_URL=...
# Default points to the korsair-api Kubernetes Service (in-cluster use).
ENV API_URL=http://korsair-api:8090

COPY --from=builder /frontend/node_modules ./node_modules
COPY --from=builder /frontend/dist ./dist
COPY --from=builder /frontend/server.mjs ./server.mjs
COPY --from=builder /frontend/package.json ./package.json

USER 1000:1000
EXPOSE 8080

CMD ["node", "server.mjs"]
